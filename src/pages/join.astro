---
import { getEntry, render } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';

const joinEntry = await getEntry('join', 'index');
const { Content } = joinEntry ? await render(joinEntry) : { Content: null };
const pageTitle = joinEntry?.data.title ?? 'Join';
---

<BaseLayout title={pageTitle} description={pageTitle} heading={pageTitle}>
    <section class="page-band py-10">
        <article class="prose-lab markdown-page">
            {Content && <Content />}
        </article>
    </section>
</BaseLayout>
