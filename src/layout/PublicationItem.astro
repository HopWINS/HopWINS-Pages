---
import type { CollectionEntry } from 'astro:content';

type PublicationPaper = CollectionEntry<'publication'>['data']['publication'][number];

interface Props {
    paper: PublicationPaper;
    researchLinks?: Record<string, { label: string; href: string }>;
}

const { paper, researchLinks = {} } = Astro.props;
const data = paper;
const researchIds = [...new Set(data.research ?? [])];
const researchTags = researchIds.map((id) => researchLinks[id] ?? { label: id, href: `/research/${id}/` });

type ActionLink = {
    id: string;
    label: string;
    url: string;
};

function isActionLink(link: ActionLink | undefined): link is ActionLink {
    return Boolean(link?.url);
}

function resolvePublicationHref(href: string) {
    if (/^(https?:|mailto:|\/|#)/.test(href)) {
        return href;
    }

    const normalized = href.replace(/^\.?\//, '');
    const assetPath = normalized.replace(/^assets\//, '');
    return `/publication/${data.id}/${assetPath}`;
}

function buildLink(id: string, href: string): ActionLink {
    return {
        id,
        label: id.replace(/[-_]/g, ' ').replace(/\b\w/g, (letter) => letter.toUpperCase()),
        url: resolvePublicationHref(href),
    };
}

const links = data.links ?? {};
const primaryHref = links.website ? resolvePublicationHref(links.website) : undefined;
const projectHref = data.project ? `/project/${data.id}/` : undefined;
const actionLinks: ActionLink[] = [
    projectHref ? { id: 'project', label: 'Project', url: projectHref } : undefined,
    ...Object.entries(links)
        .filter(([id]) => id !== 'website')
        .map(([id, href]) => buildLink(id, href)),
].filter(isActionLink);

function isDownloadLink(link: ActionLink) {
    return /\.pdf($|[?#])/i.test(link.url) || link.id.toLowerCase().includes('pdf');
}
---

<article class:list={['row-card p-4', data.highlight ? 'border-lab-gold bg-amber-50/60' : '']}>
    <div class="flex flex-col gap-1.5 md:flex-row md:items-start md:justify-between">
        <p class="text-sm font-semibold leading-5 text-lab-blue">
            {data.venue}
        </p>

        {(researchTags.length > 0 || data.award) && (
            <div class="flex flex-wrap gap-2 md:justify-end">
                {researchTags.map((tag) => <a class="rounded-md border border-transparent bg-lab-sky px-2.5 py-1 text-xs font-semibold text-lab-blue no-underline transition hover:bg-lab-blue hover:text-white" href={tag.href}>{tag.label}</a>)}
                {data.award && <span class="rounded-md bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-900">{data.award}</span>}
            </div>
        )}
    </div>

    <h3 class="mt-1.5 text-base font-semibold leading-6 text-slate-950">
        {
            primaryHref ? (
                <a class="text-slate-950 no-underline hover:text-lab-blue" href={primaryHref}>
                    {data.title}
                </a>
            ) : (
                data.title
            )
        }
    </h3>
    <p class="mt-1 text-sm leading-5 text-slate-600">{data.authors.join(', ')}</p>

    {
        actionLinks.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
                {actionLinks.map((link) => (
                    <a class="rounded-md border border-slate-300 bg-white px-2.5 py-1 text-xs font-medium text-slate-700 no-underline transition hover:border-lab-blue hover:bg-lab-sky/60 hover:text-lab-blue" href={link.url} download={isDownloadLink(link) ? true : undefined}>
                        {link.label}
                    </a>
                ))}
            </div>
        )
    }
</article>
