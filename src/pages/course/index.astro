---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';

const coursePage = await getEntry('course', 'index');

if (!coursePage) {
    throw new Error('Missing src/content/course/index.md');
}

const courses = coursePage.data.courses;
const teaching = coursePage.data.teaching;
const coursesById = new Map(courses.map((course) => [course.id, course]));
const pageTitle = coursePage.data.title;
---

<BaseLayout title={pageTitle} description={pageTitle} heading={pageTitle}>
    <section class="page-band py-10">
        <div class="grid gap-5">
            {
                courses.map((course) => {
                    const href = `/course/${course.id}/`;

                    return (
                        <article class="row-card border-l-4 border-l-lab-blue p-5">
                            <div>
                                {(course.code || course.semester) && (
                                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-semibold text-lab-blue">
                                        {course.code && <span>{course.code}</span>}
                                        {course.code && course.semester && <span class="h-4 border-l border-slate-300" aria-hidden="true"></span>}
                                        {course.semester && <span>{course.semester}</span>}
                                    </div>
                                )}
                                <h2 class="mt-2 font-serif text-xl font-semibold tracking-normal text-slate-950 md:text-[1.35rem]">
                                    <a class="text-slate-950 no-underline hover:text-lab-blue" href={href}>{course.title}</a>
                                </h2>
                                {course.description && <p class="mt-3 text-pretty leading-7 text-slate-600">{course.description}</p>}
                            </div>
                        </article>
                    );
                })
            }
        </div>

        {
            teaching.length > 0 && (
                <section class="mt-12 border-t border-slate-200 pt-8" aria-labelledby="teaching">
                    <h2 id="teaching" class="mb-4 font-serif text-2xl font-semibold tracking-normal text-slate-950">Teaching</h2>
                    <div>
                        <ul class="border-t border-slate-200">
                            {teaching.map((offering, index) => {
                                const course = coursesById.get(offering.id);

                                return (
                                    <li class:list={['grid gap-2 py-3 text-sm sm:grid-cols-[9rem_minmax(0,1fr)] sm:gap-5', index > 0 && 'border-t border-slate-200']}>
                                        <span class="font-semibold text-lab-blue">{offering.semester}</span>
                                        {course ? (
                                            <span class="font-medium text-slate-900">
                                                {course.shortName ?? course.title}
                                                {course.code && <span class="ml-2 text-slate-500">{course.code}</span>}
                                            </span>
                                        ) : (
                                            <span class="text-slate-600">{offering.id}</span>
                                        )}
                                    </li>
                                );
                            })}
                        </ul>
                    </div>
                </section>
            )
        }
    </section>
</BaseLayout>
