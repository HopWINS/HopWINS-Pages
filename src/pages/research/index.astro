---
import { getEntry } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

const researchPage = await getEntry('research', 'index');
const publicationPage = await getEntry('publication', 'index');

if (!researchPage) {
    throw new Error('Missing src/content/research/index.md');
}

const researchAssets = import.meta.glob<ImageMetadata>('/src/content/research/*/assets/*.{jpg,jpeg,png,webp,svg}', {
    import: 'default',
    eager: true,
});
const researchEntries = researchPage.data.areas;
const publications = publicationPage?.data.publication ?? [];
const pageTitle = researchPage.data.title;
const defaultPublicationLimit = researchPage.data.pubLimit;

type PublicationPaper = CollectionEntry<'publication'>['data']['publication'][number];

function resolveResearchImage(areaId: string, src: string) {
    if (/^(https?:|\/)/.test(src)) {
        return undefined;
    }

    const normalized = src.replace(/^\.?\//, '');
    const assetPath = /^(assets\/|\.\.\/)/.test(normalized) ? normalized : `assets/${normalized}`;
    return researchAssets[`/src/content/research/${areaId}/${assetPath}`];
}

function resolvePublicationHref(paper: PublicationPaper, href: string) {
    if (/^(https?:|mailto:|\/|#)/.test(href)) {
        return href;
    }

    const normalized = href.replace(/^\.?\//, '').replace(/^assets\//, '');
    return `/publication/${paper.id}/${normalized}`;
}

function paperHref(paper: PublicationPaper) {
    const website = Object.entries(paper.links ?? {}).find(([key]) => key.toLowerCase() === 'website');

    if (website) {
        return resolvePublicationHref(paper, website[1]);
    }

    return paper.project ? `/project/${paper.id}/` : undefined;
}

function recentPublications(areaId: string, limit: number) {
    if (limit === 0) {
        return [];
    }

    return publications
        .filter((paper) => paper.research.includes(areaId))
        .sort((a, b) => b.date.getTime() - a.date.getTime())
        .slice(0, limit);
}
---

<BaseLayout title={pageTitle} description={pageTitle} heading={pageTitle}>
    <section class="page-band py-10">
        <div class="border-t border-slate-200">
            {
                researchEntries.map((entry) => {
                    const href = `/research/${entry.id}/`;
                    const cover = entry.image[0];
                    const coverSrc = resolveResearchImage(entry.id, cover.src);
                    const pubLimit = entry.pubLimit ?? defaultPublicationLimit;
                    const recentPapers = recentPublications(entry.id, pubLimit);

                    return (
                    <article class:list={[
                        'grid gap-5 border-b border-slate-200 py-7 lg:items-start',
                        recentPapers.length > 0
                            ? 'lg:grid-cols-[14rem_minmax(0,4fr)_minmax(18rem,5fr)]'
                            : 'lg:grid-cols-[14rem_minmax(0,1fr)]',
                    ]}>
                        <a class="block aspect-[4/3] overflow-hidden rounded-md bg-slate-100 no-underline" href={href} aria-label={`Open ${entry.name}`}>
                            {coverSrc && <Image class="h-full w-full object-cover" src={coverSrc} alt={cover.alt} loading="lazy" />}
                        </a>
                        <div class="min-w-0">
                            <h2 class="font-serif text-2xl font-semibold tracking-normal text-slate-950">
                                <a class="text-slate-950 no-underline hover:text-lab-blue" href={href}>
                                    {entry.name}
                                </a>
                            </h2>
                            {entry.description && <p class="mt-3 max-w-3xl leading-7 text-slate-600">{entry.description}</p>}
                        </div>

                        {
                            recentPapers.length > 0 && (
                                <aside class="border-t border-slate-200 pt-4 lg:border-t-0 lg:border-l-2 lg:border-l-lab-blue lg:pt-0 lg:pl-4" aria-label={`Recent publications for ${entry.name}`}>
                                    <ol class="grid gap-3">
                                        {recentPapers.map((paper) => {
                                            const link = paperHref(paper);
                                            const displayTitle = paper.shortTitle ?? paper.title;

                                            return (
                                                <li>
                                                    <p class="text-xs font-semibold text-lab-blue">{paper.venue}</p>
                                                    <h3 class="mt-0.5 text-sm font-medium leading-5 text-slate-950">
                                                        {link ? (
                                                            <a class="text-slate-950 no-underline hover:text-lab-blue" href={link}>
                                                                {displayTitle}
                                                            </a>
                                                        ) : (
                                                            displayTitle
                                                        )}
                                                    </h3>
                                                </li>
                                            );
                                        })}
                                    </ol>
                                </aside>
                            )
                        }
                    </article>
                    );
                })
            }
        </div>
    </section>
</BaseLayout>
