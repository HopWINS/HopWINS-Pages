---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import PublicationItem from '@/layout/PublicationItem.astro';
import site from '@/content/config/site.json';
import { byNewestDate, yearFromDate } from '@/lib/content';
import type { CollectionEntry } from 'astro:content';

interface PublicationRow {
    publication: CollectionEntry<'publication'>;
    year: number;
}

const publications = (await getCollection('publication', ({ data }) => !data.draft)).sort(byNewestDate);
const publicationRows = publications.map((publication) => ({
    publication,
    year: yearFromDate(publication.data.date),
}));

const grouped = publicationRows.reduce<Map<number, PublicationRow[]>>((groups, row) => {
    const rows = groups.get(row.year) ?? [];
    rows.push(row);
    groups.set(row.year, rows);
    return groups;
}, new Map<number, PublicationRow[]>());
const page = site.pages.publication;
---

<BaseLayout title={page.title} description={page.description} heading={page.title}>
    <section class="page-band grid gap-8 py-10">
        {
            [...grouped.entries()].map(([year, rows]) => (
                <section aria-labelledby={`year-${year}`}>
                    <h2 id={`year-${year}`} class="mb-4 font-serif text-3xl font-semibold tracking-normal text-slate-950">{year}</h2>
                    <div class="grid gap-4">
                        {rows.map((row) => <PublicationItem publication={row.publication} />)}
                    </div>
                </section>
            ))
        }
    </section>
</BaseLayout>
