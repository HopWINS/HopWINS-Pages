---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import { entrySlug, folderRoute } from '@/lib/content';

export async function getStaticPaths() {
    const courses = await getCollection('coursePage');

    return courses
        .filter((course) => entrySlug(course) !== 'index')
        .map((course) => {
            const courseId = entrySlug(course).split('/')[0] ?? '';

            return {
                params: { slug: folderRoute(course) },
                props: {
                    course,
                    courseId,
                    basePath: `/course/${courseId}/`,
                },
            };
        });
}

const { course, courseId, basePath } = Astro.props;
const { Content } = await render(course);
const coursePage = await getEntry('course', 'index');
const courseMeta = coursePage?.data.courses.find((item) => item.id === courseId);
const displayTitle = courseMeta?.title ?? 'Course';
const description = courseMeta?.description ?? displayTitle;
const courseNote = [courseMeta?.code, courseMeta?.semester].filter(Boolean).join(' | ');
---

<BaseLayout title={displayTitle} description={description} basePath={basePath} heading={displayTitle} eyebrow={courseNote}>
    <section class="page-band py-10">
        <article class="prose-lab markdown-page">
            <Content />
        </article>
    </section>
</BaseLayout>
