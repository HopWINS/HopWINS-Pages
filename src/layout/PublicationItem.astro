---
import { yearFromDate } from '@/lib/content';

interface LinkItem {
    label: string;
    url: string;
    kind?: string;
}

interface PublicationData {
    title: string;
    authors: string[];
    date: Date;
    venue: string;
    venueType: string;
    conference?: string;
    award?: string;
    highlight?: boolean;
    links?: LinkItem[];
    youtube?: string;
}

interface Props {
    publication: { data: PublicationData };
}

const { publication } = Astro.props;
const data = publication.data;
const year = yearFromDate(data.date);
---

<article class:list={['row-card p-5', data.highlight ? 'border-lab-gold bg-amber-50/60' : '']}>
    <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
            <h3 class="text-lg font-semibold leading-7 text-slate-950">{data.title}</h3>
            <p class="mt-1 text-sm leading-6 text-slate-600">{data.authors.join(', ')}</p>
            <p class="mt-1 text-sm font-medium text-slate-700">
                {data.venue}
                <span class="text-slate-400">/</span>
                {year}
            </p>
        </div>

        <div class="flex flex-wrap gap-2 md:justify-end">
            <span class="rounded-md bg-lab-sky px-2.5 py-1 text-xs font-semibold text-lab-blue">{data.venueType}</span>
            {data.conference && <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">{data.conference}</span>}
            {data.award && <span class="rounded-md bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-900">{data.award}</span>}
        </div>
    </div>

    {
        ((data.links && data.links.length > 0) || data.youtube) && (
            <div class="mt-4 flex flex-wrap gap-2">
                {data.links?.map((link) => (
                    <a class="rounded-md border border-slate-200 px-3 py-1.5 text-sm font-medium text-lab-blue no-underline hover:border-lab-teal hover:text-lab-teal" href={link.url}>
                        {link.label}
                    </a>
                ))}
                {data.youtube && (
                    <a class="rounded-md border border-slate-200 px-3 py-1.5 text-sm font-medium text-lab-blue no-underline hover:border-lab-teal hover:text-lab-teal" href={data.youtube}>
                        YouTube
                    </a>
                )}
            </div>
        )
    }
</article>
