---
import { getEntry } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import BaseLayout from '@/layout/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const home = await getEntry('index', 'index');
const newsEntry = await getEntry('news', 'index');
const site = await getEntry('site', 'index');
const title = home?.data.title ?? site?.data.labName ?? 'HopWINS Lab';
const description = home?.data.description ?? '';
const metaDescription = description || site?.data.labName || title;
const newsTitle = newsEntry?.data.title ?? 'News';
type HeroSlide = {
    src: ImageMetadata;
    alt: string;
    caption?: string;
};

const slides = (home?.data.heroImages ?? []) as HeroSlide[];
const firstSlideImage = slides[0]?.src;
const firstSlideUrl = firstSlideImage?.src;
const collapsedNewsCount = home?.data.newsLimit ?? 6;
const markdownProcessor = await createMarkdownProcessor();
const news = await Promise.all(
    (newsEntry?.data.news ?? [])
        .sort((a, b) => b.date.getTime() - a.date.getTime())
        .map(async (item) => ({
            ...item,
            html: (await markdownProcessor.render(item.text)).code,
        })),
);
const newsDateFormatter = new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
});
---

<BaseLayout title={title} description={metaDescription} image={firstSlideUrl}>
    <section class="bg-white">
        <div class="page-band grid gap-8 py-8 lg:grid-cols-3 lg:items-stretch lg:py-12">
            <div class="flex flex-col justify-center border-l-[6px] border-lab-blue pl-5 lg:col-span-1">
                <h1 class="font-serif text-4xl font-semibold leading-tight tracking-normal text-slate-950 md:text-5xl">
                    {title}
                </h1>
                {description && <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>}
            </div>

            <div class="lg:col-span-2">
                <div class="relative overflow-hidden rounded-lg border border-slate-200 bg-slate-100 shadow-sm" data-carousel>
                    <div class="relative aspect-[16/9]">
                        {
                            slides.map((slide, index) => (
                                <figure
                                    class:list={[
                                        'absolute inset-0 transition-opacity duration-500',
                                        index === 0 ? 'opacity-100' : 'opacity-0',
                                    ]}
                                    data-slide
                                >
                                    <Image
                                        class="h-full w-full object-cover"
                                        src={slide.src}
                                        alt={slide.alt}
                                        loading={index === 0 ? 'eager' : 'lazy'}
                                    />
                                    {slide.caption && <figcaption class="absolute bottom-0 left-0 right-0 bg-slate-950/55 px-4 py-2 text-sm text-white">{slide.caption}</figcaption>}
                                </figure>
                            ))
                        }
                    </div>

                    {
                        slides.length > 1 && (
                            <>
                                <button
                                    class="absolute left-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-slate-950/20 text-white ring-1 ring-white/30 backdrop-blur transition hover:bg-slate-950/35 hover:ring-white/60"
                                    type="button"
                                    data-carousel-prev
                                    aria-label="Previous image"
                                >
                                    <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M15 18L9 12L15 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
                                    </svg>
                                </button>
                                <button
                                    class="absolute right-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-slate-950/20 text-white ring-1 ring-white/30 backdrop-blur transition hover:bg-slate-950/35 hover:ring-white/60"
                                    type="button"
                                    data-carousel-next
                                    aria-label="Next image"
                                >
                                    <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M9 18L15 12L9 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
                                    </svg>
                                </button>
                            </>
                        )
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="page-band py-10" aria-labelledby="news-heading">
        <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <h2 id="news-heading" class="font-serif text-3xl font-semibold tracking-normal text-slate-950">{newsTitle}</h2>
            </div>
        </div>

        <ol class="border-t border-slate-200">
            {
                news.map((item, index) => (
                    <li
                        class:list={[
                            'grid gap-2 py-3 sm:grid-cols-[8.5rem_minmax(0,1fr)] sm:gap-5',
                            index > 0 && 'border-t border-slate-200',
                            index >= collapsedNewsCount && 'hidden',
                        ]}
                        data-news-item={index >= collapsedNewsCount ? 'extra' : undefined}
                    >
                        <time class="text-sm font-semibold text-lab-blue" datetime={item.date.toISOString()}>
                            {newsDateFormatter.format(item.date)}
                        </time>
                        <div class="news-line text-sm leading-6 text-slate-700" set:html={item.html} />
                    </li>
                ))
            }
        </ol>
        {
            news.length > collapsedNewsCount && (
                <button class="mt-4 rounded-md border border-slate-200 px-3.5 py-2 text-sm font-medium text-lab-blue transition hover:border-lab-blue hover:bg-lab-sky" type="button" data-news-more aria-expanded="false">
                    Show more
                </button>
            )
        }
    </section>

    <script>
        const newsMore = document.querySelector('[data-news-more]');
        const extraNews = document.querySelectorAll('[data-news-item="extra"]');

        newsMore?.addEventListener('click', () => {
            const expanded = newsMore.getAttribute('aria-expanded') === 'true';

            for (const item of extraNews) {
                item.classList.toggle('hidden', expanded);
            }

            newsMore.setAttribute('aria-expanded', String(!expanded));
            newsMore.textContent = expanded ? 'Show more' : 'Show less';
        });
    </script>
</BaseLayout>
