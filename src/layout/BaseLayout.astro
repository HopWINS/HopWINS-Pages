---
import { getEntry } from 'astro:content';
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    basePath?: string;
    heading?: string;
    eyebrow?: string;
}

const siteEntry = await getEntry('site', 'index');

if (!siteEntry) {
    throw new Error('Missing src/content/site/index.md');
}

const site = siteEntry.data;
const sortedNav = site.nav.map((item) => ({
    ...item,
    href: item.id === 'home' ? '/' : `/${item.id}`,
}));
const { title = site.labName, description = site.labName, image, basePath, heading, eyebrow } = Astro.props;
const pageTitle = title === site.labName ? site.labName : `${title} | ${site.labName}`;
const canonical = new URL(Astro.url.pathname, site.siteUrl).toString();
const currentPath = Astro.url.pathname;
const labIcon = typeof site.labIcon === 'string' ? site.labIcon : site.labIcon?.src;
const currentYear = new Date().getFullYear();
const contactEmailHref = site.footer.contact.email.includes('@') ? `mailto:${site.footer.contact.email}` : null;
const configAssets = import.meta.glob<string>('/src/content/site/assets/*.{jpg,jpeg,png,webp,svg}', {
    query: '?url',
    import: 'default',
    eager: true,
});

function assetPath(src: string | undefined) {
    if (!src) {
        return undefined;
    }

    if (/^(https?:|data:|\/)/.test(src)) {
        return src;
    }

    const normalized = src.replace(/^\.?\//, '');
    return configAssets[`/src/content/site/assets/${normalized}`] ?? src;
}

function isActive(href: string) {
    if (href === '/') {
        return currentPath === '/';
    }

    return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        {basePath && <base href={basePath} />}
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" href="/favicon.ico" />
        <link rel="canonical" href={canonical} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        {image && <meta property="og:image" content={new URL(image, site.siteUrl).toString()} />}
        <title>{pageTitle}</title>
    </head>
    <body class="flex min-h-screen flex-col bg-white">
        <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
            <div class="page-band flex flex-col gap-3 py-3 lg:flex-row lg:items-center lg:justify-between">
                <a class="flex min-w-0 items-center gap-3 text-slate-950 no-underline" href="/" aria-label={`${site.labName} home`}>
                    {
                        labIcon && (
                            <img class="h-9 w-9 shrink-0 object-contain" src={assetPath(labIcon)} alt="" />
                        )
                    }
                    <span class="truncate text-xl font-semibold tracking-normal">{site.labName}</span>
                </a>

                <nav aria-label="Main navigation">
                    <ul class="flex flex-wrap gap-1.5">
                        {
                            sortedNav.map((item) => (
                                <li>
                                    <a
                                        class:list={[
                                            'inline-flex min-h-10 items-center rounded-md px-3.5 text-[0.95rem] font-medium no-underline transition',
                                            isActive(item.href)
                                                ? 'bg-lab-blue text-white'
                                                : 'text-slate-700 hover:bg-slate-100 hover:text-lab-blue',
                                        ]}
                                        href={item.href}
                                        aria-current={isActive(item.href) ? 'page' : undefined}
                                    >
                                        {item.label}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </nav>
            </div>
        </header>
        <main id="content" class="flex-1">
            {
                heading && (
                    <section class="border-b border-slate-200 bg-white">
                        <div class="page-band py-6">
                            <h1 class="font-serif text-2xl font-semibold tracking-normal text-slate-950 md:text-3xl">{heading}</h1>
                            {eyebrow && (
                                <div class="mt-4 max-w-4xl">
                                    <p class="text-sm font-semibold text-lab-blue">{eyebrow}</p>
                                </div>
                            )}
                        </div>
                    </section>
                )
            }
            <slot />
        </main>
        <footer class="border-t border-slate-200 bg-white">
            <div class="page-band flex flex-col gap-4 py-3 md:flex-row md:items-center md:justify-between">
                <section aria-label="Contact" class="space-y-1.5 text-sm font-medium text-slate-600">
                    <p class="flex items-start gap-2">
                        <img class="mt-0.5 h-4 w-4 shrink-0" src={assetPath(site.footer.contact.addressIcon.src)} alt={site.footer.contact.addressIcon.alt} loading="lazy" />
                        {site.footer.contact.location}
                    </p>
                    {
                        contactEmailHref ? (
                            <a class="flex items-center gap-2 text-slate-600 no-underline hover:text-lab-blue" href={contactEmailHref}>
                                <img class="h-4 w-4 shrink-0" src={assetPath(site.footer.contact.emailIcon.src)} alt={site.footer.contact.emailIcon.alt} loading="lazy" />
                                {site.footer.contact.email}
                            </a>
                        ) : (
                            <p class="flex items-center gap-2 text-slate-600">
                                <img class="h-4 w-4 shrink-0" src={assetPath(site.footer.contact.emailIcon.src)} alt={site.footer.contact.emailIcon.alt} loading="lazy" />
                                {site.footer.contact.email}
                            </p>
                        )
                    }
                </section>

                <div class="flex flex-col items-start gap-0.5 md:items-center">
                    <section class="flex items-center gap-3 text-left text-sm font-medium leading-5 text-slate-700 md:text-center" aria-label="School">
                        {
                            site.footer.school.logo && (
                                <img class="h-11 w-auto max-w-60 object-contain" src={assetPath(site.footer.school.logo.src)} alt={site.footer.school.logo.alt} loading="lazy" />
                            )
                        }
                        <span class="h-8 border-l border-slate-300" aria-hidden="true"></span>
                        <span class="whitespace-pre-line text-center text-[0.8em] leading-4">{site.footer.school.name}</span>
                    </section>
                    <p class="text-center text-xs leading-4 text-slate-500">© {currentYear} {site.labName}</p>
                </div>
            </div>
        </footer>
        <script>
            const carousels = document.querySelectorAll('[data-carousel]');

            for (const carousel of carousels) {
                const slides = Array.from(carousel.querySelectorAll('[data-slide]'));
                const prev = carousel.querySelector('[data-carousel-prev]');
                const next = carousel.querySelector('[data-carousel-next]');
                let active = 0;

                const showSlide = (target: number) => {
                    if (slides.length === 0) return;
                    slides[active].classList.remove('opacity-100');
                    slides[active].classList.add('opacity-0');
                    active = (target + slides.length) % slides.length;
                    slides[active].classList.remove('opacity-0');
                    slides[active].classList.add('opacity-100');
                };

                prev?.addEventListener('click', () => showSlide(active - 1));
                next?.addEventListener('click', () => showSlide(active + 1));

                if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && slides.length > 1) {
                    window.setInterval(() => showSlide(active + 1), 7000);
                }
            }
        </script>
    </body>
</html>
