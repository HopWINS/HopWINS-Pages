---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import PublicationItem from '@/layout/PublicationItem.astro';
import { byNewestDate, entrySlug } from '@/lib/content';

export async function getStaticPaths() {
    const researchEntries = await getCollection('research', ({ data }) => !data.draft);

    return researchEntries.map((entry) => ({
        params: { slug: entrySlug(entry) },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const slug = entrySlug(entry);
const { Content } = await render(entry);
const gallery = entry.data.gallery.length > 0 ? entry.data.gallery : [entry.data.image];
const publicationIds = new Set(entry.data.publicationIds);
const publications = (await getCollection('publication', ({ data }) => !data.draft))
    .filter((publication) => publicationIds.has(entrySlug(publication)) || publication.data.research.includes(slug))
    .sort(byNewestDate);
---

<BaseLayout title={entry.data.title} description={entry.data.summary} image={entry.data.image.src} heading={entry.data.title}>
    <section class="page-band grid gap-8 py-10 lg:grid-cols-[minmax(320px,0.9fr)_minmax(0,1.1fr)] lg:items-start">
        <div class="relative overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm lg:sticky lg:top-28" data-carousel>
            <div class="relative aspect-[4/3]">
                {
                    gallery.map((image, index) => (
                        <figure
                            class:list={[
                                'absolute inset-0 transition-opacity duration-500',
                                index === 0 ? 'opacity-100' : 'opacity-0',
                            ]}
                            data-slide
                        >
                            <img class="h-full w-full object-cover" src={image.src} alt={image.alt} loading={index === 0 ? 'eager' : 'lazy'} />
                            {image.caption && <figcaption class="absolute bottom-0 left-0 right-0 bg-slate-950/55 px-4 py-2 text-sm text-white">{image.caption}</figcaption>}
                        </figure>
                    ))
                }
            </div>

            {
                gallery.length > 1 && (
                    <>
                        <button
                            class="absolute left-3 top-1/2 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md bg-white/45 text-sm font-semibold text-slate-900/70 backdrop-blur transition hover:bg-white/75"
                            type="button"
                            data-carousel-prev
                            aria-label="Previous image"
                        >
                            &lt;
                        </button>
                        <button
                            class="absolute right-3 top-1/2 flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md bg-white/45 text-sm font-semibold text-slate-900/70 backdrop-blur transition hover:bg-white/75"
                            type="button"
                            data-carousel-next
                            aria-label="Next image"
                        >
                            &gt;
                        </button>
                    </>
                )
            }
        </div>

        <article class="prose-lab">
            <Content />
        </article>
    </section>

    <section class="page-band pb-12" aria-labelledby="related-publications">
        <h2 id="related-publications" class="mb-4 font-serif text-3xl font-semibold tracking-normal text-slate-950">Related Papers</h2>
        {
            publications.length > 0 ? (
                <div class="grid gap-4">
                    {publications.map((publication) => <PublicationItem publication={publication} />)}
                </div>
            ) : (
                <p class="rounded-lg border border-slate-200 bg-white p-5 text-slate-600">Related publications will appear here when publication Markdown files reference this research area.</p>
            )
        }
    </section>
</BaseLayout>
