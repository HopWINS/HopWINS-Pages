---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import site from '@/content/config/site.json';
import courseConfig from '@/content/course/config.json';
import { isFolderIndex, orderedFolderRoute } from '@/lib/content';

const courseOrder = new Map(courseConfig.order.map((slug, index) => [slug, index]));
const courses = (await getCollection('course', ({ data }) => !data.draft))
    .filter(isFolderIndex)
    .sort((a, b) => {
        const orderDiff = (courseOrder.get(orderedFolderRoute(a)) ?? 999) - (courseOrder.get(orderedFolderRoute(b)) ?? 999);
        if (orderDiff !== 0) {
            return orderDiff;
        }

        return (a.data.title ?? a.data.shortName ?? '').localeCompare(b.data.title ?? b.data.shortName ?? '');
    });
const page = site.pages.course;
---

<BaseLayout title={page.title} description={page.description} heading={page.title}>
    <section class="page-band py-10">
        <div class="grid gap-5">
            {
                courses.map((course) => {
                    const href = `/course/${orderedFolderRoute(course)}/`;

                    return (
                        <article class="row-card border-l-4 border-l-lab-blue p-5">
                            <div>
                                {(course.data.code || course.data.semester) && (
                                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-semibold text-lab-blue">
                                        {course.data.code && <span>{course.data.code}</span>}
                                        {course.data.code && course.data.semester && <span class="h-4 border-l border-slate-300" aria-hidden="true"></span>}
                                        {course.data.semester && <span>{course.data.semester}</span>}
                                    </div>
                                )}
                                <h2 class="mt-2 font-serif text-2xl font-semibold tracking-normal text-slate-950">
                                    <a class="text-slate-950 no-underline hover:text-lab-blue" href={href}>{course.data.title ?? course.data.shortName}</a>
                                </h2>
                                {course.data.note && <p class="mt-3 text-pretty leading-7 text-slate-600">{course.data.note}</p>}
                            </div>
                        </article>
                    );
                })
            }
        </div>
    </section>
</BaseLayout>
