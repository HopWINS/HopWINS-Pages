---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layout/BaseLayout.astro';
import { isFolderIndex, orderedContentDirectoryRoute, orderedFolderRoute } from '@/lib/content';

export async function getStaticPaths() {
    const courses = await getCollection('course', ({ data }) => !data.draft);
    const courseIndexes = new Map(
        courses.filter(isFolderIndex).map((course) => [orderedContentDirectoryRoute(course), course]),
    );

    return courses.map((course) => ({
        params: { slug: orderedFolderRoute(course) },
        props: {
            course,
            rootCourse: courseIndexes.get(orderedContentDirectoryRoute(course)) ?? course,
            basePath: `/course/${orderedContentDirectoryRoute(course)}/`,
        },
    }));
}

const { course, rootCourse, basePath } = Astro.props;
const { Content } = await render(course);
const metaItems = [rootCourse.data.code, rootCourse.data.semester].filter(Boolean);
const metaNote = metaItems.join(' | ');
const displayTitle = rootCourse.data.shortName ?? rootCourse.data.title ?? course.data.title ?? 'Course';
const description = rootCourse.data.note ?? displayTitle;
---

<BaseLayout title={displayTitle} description={description} basePath={basePath} heading={displayTitle} eyebrow={metaNote}>
    <section class="page-band py-10">
        <article class="prose-lab rounded-md border border-slate-200 bg-white p-6">
            <Content />
        </article>
    </section>
</BaseLayout>
